comp Area(w: int, h: int);

fun(Area) doubled(a: Area) { return Area(a.w * 2, a.h * 2); }

fun() main() {
    let mut a = Area(5, 10);
    a = doubled(a);
    if a.w is 10{
        if false{
            println("wow");
        } else if a.h is 20{
            println("wower");
            println(a.h is a.w);
        }
    } else {
        println("no math");
    }
}
